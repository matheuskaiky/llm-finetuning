# Example environment file. Copy to .env and fill in real values.
# .env is git-ignored; this .env.example is tracked. Keep both in sync:
# whenever code or tooling starts reading a new variable, add it here.
# Load before running, e.g.: set -a; source .env; set +a

# --- Hugging Face ---
# Access token (https://huggingface.co/settings/tokens). Needed for gated or
# private repos and for higher download rate limits. Leave empty for public models.
HF_TOKEN=
# Cache/root dir for downloaded models and datasets. Defaults to ~/.cache/huggingface.
# Keep this COMMENTED unless you set a real path: an empty HF_HOME makes the HF
# cache land in ./hub of the current directory.
# HF_HOME=/path/to/hf-cache
# Use the Rust-based fast downloader (requires the hf_transfer package). 1 to enable.
HF_HUB_ENABLE_HF_TRANSFER=1

# --- Model selection ---
# Default model for scripts/download_assets.py. Per-question models are pinned in
# the YAML configs (Q1-Q3 use Qwen3-*-Base; Q5 RAG uses Qwen3-8B / the 30B FP8).
BASE_MODEL_ID=Qwen/Qwen3-8B

# --- Dataset ---
# Training corpus: Diario Oficial dos Municipios do Piaui 2025 (text in the "texto" column).
DATASET_ID=gutoportelaa/dom-pi-corpus-2025

# --- GitHub (opcional; usado por tarefas que criam/atualizam issues via API) ---
# Personal access token com escopo de issues (classic: repo; fine-grained: Issues RW).
# Git-ignored. Deixe vazio se nao for mexer em issues pela linha de comando.
GITHUB_TOKEN=

# --- Hardware ---
# GPUs visible to the process. This machine has 2x NVIDIA L4 (indices 0 and 1).
CUDA_VISIBLE_DEVICES=0,1
# Silence the tokenizers fork warning during data loading.
TOKENIZERS_PARALLELISM=false

# --- Experiment tracking (optional) ---
# Weights and Biases. Set WANDB_MODE=online and a key to log runs, or keep offline.
WANDB_API_KEY=
WANDB_MODE=offline
